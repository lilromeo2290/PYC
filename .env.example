# Environment variables for PYC Club website
# Copy this file to .env on your VPS and adjust values as needed

# Database (not used in production — only needed if you add a database later)
DATABASE_URL="file:./db/custom.db"

# Node environment
NODE_ENV="production"

# Port the app runs on (change if needed)
PORT=3000

# Your domain (for SEO/Open Graph metadata)
# Update this to your actual domain
NEXT_PUBLIC_SITE_URL="https://pycclub.org"
